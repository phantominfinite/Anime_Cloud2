# ---- Runtime ----
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://anime:animepass@localhost:5432/anime_db

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Telegram (optional for local dev) ----
API_ID=
API_HASH=
BOT_TOKEN=
ADMIN_IDS=

# ---- Security ----
# REQUIRED when ENVIRONMENT=production
ADMIN_API_KEY=

# ---- CORS ----
# Comma separated. Use * only for dev.
CORS_ORIGINS=*

# ---- Cache / streaming ----
CACHE_DIR=cache
CACHE_MAX_BYTES=2147483648
STREAM_CHUNK_SIZE=1048576
STREAM_PREFETCH_CHUNKS=5

# ---- Rate limiting ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STREAM_RPM=120

# ---- WebApp ----
WEBAPP_URL=https://yourdomain.example/
